# Firebase Admin SDK credentials
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Copy the values from the downloaded JSON file into these vars.

FIREBASE_PROJECT_ID=hhg-apk
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@hhg-apk.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Simple password to protect the dashboard
DASHBOARD_PASSWORD=change-me

# Shared secret for the /api/push/send endpoint. The /send UI asks for this
# in-session (it isn't baked into the bundle). Rotate by changing this var
# and redeploying; no client changes required.
PUSH_ADMIN_SECRET=change-me-to-a-long-random-string
