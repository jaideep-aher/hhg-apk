<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base theme (XML) — only used for splash / before Compose takes over.
      Actual app theming is in Kotlin (ui/theme/Theme.kt) using Material 3.
    -->
    <!--
      XML theme is only used during the launch window (before Compose inflates).
      MUST descend from Theme.AppCompat because MainActivity is an AppCompatActivity
      (needed for AppCompatDelegate.setApplicationLocales to drive Marathi/English switching).
      Day/night is handled at runtime in `ui/theme/Theme.kt` for Compose content.
    -->
    <style name="Theme.HHGFarmers" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/hhg_orange_500</item>
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>
