<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base theme (XML) — only used for splash / before Compose takes over.
      Actual app theming is in Kotlin (ui/theme/Theme.kt) using Material 3.
    -->
    <!--
      XML theme is only used during the launch window (before Compose inflates).
      We intentionally use the built-in `android:Theme.Material.Light.NoActionBar` so
      we don't pull in MDC (Material Components for Android) just for a splash theme —
      the Compose app uses `androidx.compose.material3` which is Kotlin-only and
      ships no XML styles. Day/night is handled at runtime in `ui/theme/Theme.kt`.
    -->
    <style name="Theme.HHGFarmers" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/hhg_orange_500</item>
        <item name="android:windowBackground">@color/white</item>
    </style>
</resources>
