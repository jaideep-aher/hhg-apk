<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup scope. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="telemetry.db" />
        <exclude domain="database" path="offline_cache.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="telemetry.db" />
    </device-transfer>
</data-extraction-rules>
