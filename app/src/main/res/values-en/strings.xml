    <!-- About screen -->
    <string name="about_title">About Us</string>
    <string name="about_heading">Hanuman Hundekari</string>
    <string name="about_body">Hanuman Hundekari is a family-run vegetable trading business based in Ghargaon, Sangamner taluka, Ahmednagar district (PIN 422620), Maharashtra. For decades we have connected local farmers with wholesale markets in Mumbai and Pune, offering fair prices and timely payments. This app brings your patti, today\'s mandi rates, and market trends to your phone — so you spend less time calling and more time farming.</string>
    <string name="about_built_for">Built for the farmers of Ghargaon and the Sangamner taluka region.</string>
    <string name="about_story_title">Our story</string>
    <string name="about_story_p1">Since 1967 we started from a small hundekari that helped farmers bring produce to market. As hundekari grew in popularity, our founder Mr. Shivaji Gangadhar Aher began selling fertilisers and pesticides to visitors — now known as Hanuman Krishi Seva Kendra.</string>
    <string name="about_story_p2">Despite many challenges, Hanuman Hundekari is a trusted name in Ghargaon and the plateau region, with a long history of supporting farmers. Our commitment to the farming community has remained strong for decades.</string>
    <string name="about_stat_downloads">1000+ downloads</string>
    <string name="about_stat_years">50+ years of service</string>
