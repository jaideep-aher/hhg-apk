<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location (Uber-grade Fused Location Provider) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Push notifications (FCM). POST_NOTIFICATIONS is required from Android 13. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" />

    <!-- Photos / video library — REMOVED in v10 until we ship the image picker /
         PDF gallery flows. Each unused permission is a Play Data Safety form
         question we don't want + a conversion hit on install. Re-add the exact
         subset we actually need (likely just READ_MEDIA_IMAGES) when that
         feature lands. -->

    <!-- Specific-package visibility (NOT query-all, which is Play-restricted) -->
    <queries>
        <!-- WhatsApp (we deep-link into it for sharing patti) -->
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />
        <!-- UPI apps (adoption signal) -->
        <package android:name="com.google.android.apps.nbu.paisa.user" /> <!-- GPay -->
        <package android:name="net.one97.paytm" />                         <!-- Paytm -->
        <package android:name="com.phonepe.app" />                         <!-- PhonePe -->
        <!-- Competing agri apps -->
        <package android:name="com.agrostar.consumerapp" />
        <package android:name="com.dehaat.superapp" />
    </queries>

    <application
        android:name=".HhgApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HHGFarmers"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode|screenLayout"
            android:theme="@style/Theme.HHGFarmers">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FCM service — activates once google-services.json is added. -->
        <service
            android:name=".service.push.FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FileProvider for sharing generated PDFs via native share sheet. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- WorkManager: use our Hilt-aware initializer, not the default one. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
