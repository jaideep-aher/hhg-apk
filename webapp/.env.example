# Template for the webapp's environment variables.
#
# Copy this file to `.env.local` for local development, and set the same keys
# in your hosting provider's dashboard (Railway → Service → Variables) for
# production. DO NOT commit the real `.env` — it's gitignored.
#
# Anything exposed to the browser must be prefixed with NEXT_PUBLIC_ — Next.js
# strips every other env var from the client bundle.

# ─── Database connections ────────────────────────────────────────────────
#
# The webapp is READ-ONLY against Postgres. It has no write paths.
# Set ONLY the read-replica connection string here — never provision
# DATABASE_URLW (write primary) on this service, or Railway will
# happily inject it and a future accidental `INSERT`/`UPDATE` becomes
# possible. All writes must go through the Express backend in
# android/backend/. See android/webapp/MIGRATION.md for the long-term
# plan to delete even DATABASE_URLR and call Express for all reads.
DATABASE_URLR=postgresql://user:password@host:5432/dbname

# Neon Postgres for AI-related tables (agrisight etc.)
NEON_DB_CONNECTION_STRING=postgresql://user:password@host/dbname?sslmode=require

# ─── Express API (APMC, future read paths) ──────────────────────────────
# The Express backend at android/backend/ exposes /api/apmc/* backed by a
# separate Railway Postgres (APMC mandi prices). Public because the webapp
# calls it from the browser with React Query. Leave unset in local dev to
# hit the live API (https://api.hanumanksk.in).
NEXT_PUBLIC_API_BASE_URL=https://api.hanumanksk.in

# ─── Third-party services ────────────────────────────────────────────────
# Gemini / PaLM API key used by src/lib/aiService.js
API_KEY=your_google_ai_api_key

# PostHog product analytics (web-only — the Android shell uses its own key)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
