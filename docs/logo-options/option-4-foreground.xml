<?xml version="1.0" encoding="utf-8"?>
<!--
  Option 4 -- Sunrise over a field.
  Drop-in replacement for app/src/main/res/drawable/ic_launcher_foreground.xml
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Half sun (flat bottom at horizon y=55) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,55 m-19.5,0 a19.5,19.5 0 0 1 39,0 Z" />

    <!-- Center ray -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52.5,26 h3 a1.5,1.5 0 0 1 1.5,1.5 v6.5 a1.5,1.5 0 0 1 -1.5,1.5 h-3 a1.5,1.5 0 0 1 -1.5,-1.5 v-6.5 a1.5,1.5 0 0 1 1.5,-1.5 z" />

    <!-- Left ray (angled) -->
    <group android:pivotX="40.5" android:pivotY="33" android:rotation="-40">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M37.5,31.5 h6 a1.5,1.5 0 0 1 1.5,1.5 v0 a1.5,1.5 0 0 1 -1.5,1.5 h-6 a1.5,1.5 0 0 1 -1.5,-1.5 v0 a1.5,1.5 0 0 1 1.5,-1.5 z" />
    </group>

    <!-- Right ray (angled) -->
    <group android:pivotX="67.5" android:pivotY="33" android:rotation="40">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M64.5,31.5 h6 a1.5,1.5 0 0 1 1.5,1.5 v0 a1.5,1.5 0 0 1 -1.5,1.5 h-6 a1.5,1.5 0 0 1 -1.5,-1.5 v0 a1.5,1.5 0 0 1 1.5,-1.5 z" />
    </group>

    <!-- Three curved field furrows -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M26,65 C54,60 54,60 82,65" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M23,75 C54,68.5 54,68.5 85,75" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M21,85 C54,77.5 54,77.5 87,85" />
</vector>
