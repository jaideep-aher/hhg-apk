# Copy this to .env and fill in your values
# On Railway: add these as environment variables in the dashboard (NOT in .env)

# ─── DATABASES ────────────────────────────────────────────────────────────────
# The backend wires three logical pools. Each var is optional; anything unset
# falls back to the legacy single DATABASE_URL. Details in docs/DATABASE.md.
#
# Primary AWS RDS — read-only (farmer / patti / rates / notices)
DATABASE_URLR=postgresql://ro:<password>@<rds-host>.rds.amazonaws.com/hhg
# Primary AWS RDS — read-write (telemetry inserts, future writes)
DATABASE_URLW=postgresql://postgres:<password>@<rds-host>.rds.amazonaws.com/hhg
# Neon Postgres — AgriSight market-trend data only (wire in when the feature ships)
NEON_DB_CONNECTION_STRING=postgresql://neondb_owner:<password>@<neon-host>/neondb?sslmode=require

# Legacy fallback — if the three above aren't set, both R and W use this:
# DATABASE_URL=postgresql://username:password@your-rds-host.rds.amazonaws.com/hhg

# Port Railway will assign automatically — leave as is
PORT=3000

# A random secret used to authenticate the telemetry endpoint
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEMETRY_SECRET=change_this_to_a_random_secret

# ─── FORCE-UPDATE CONTROLS (GET /api/config) ──────────────────────────────────
# To force every user off an old APK, raise MIN_VERSION_CODE and restart the service.
# Any APK whose BuildConfig.VERSION_CODE is below this will see a blocking
# "Update Now" screen on next app launch. No code change or redeploy needed.
MIN_VERSION_CODE=1
LATEST_VERSION_CODE=1

# Play Store URL the "Update Now" button opens
# Leave blank — the Android client auto-builds the URL from its own package name.
# Only set this if you want to deliberately override (e.g. redirect users to a
# different listing during a package ID migration).
PLAY_STORE_URL=

# Text shown on the block screen (Marathi). Override if you want to explain
# the reason a specific update is required.
FORCE_UPDATE_TITLE=अॅप अपडेट करा
FORCE_UPDATE_MESSAGE=पुढे जाण्यासाठी कृपया अॅपचे नवीन व्हर्जन इन्स्टॉल करा. जुने व्हर्जन आता सपोर्टेड नाही.

# ─── WEBVIEW HOSTS (GET /api/config) ──────────────────────────────────────────
# Base URL of the Next.js site (android/webapp) whose pages the Android shell
# hosts inside WebViews. Change this to your production domain (e.g.
# https://www.hanumanksk.in) without requiring an APK release. The APK's
# baked-in default is a temporary staging host.
WEB_BASE_URL=https://1.aher.dev

# Optional secondary website host used as fallback when the primary is down.
# Leave blank to disable fallback.
# WEB_BASE_URL_FALLBACK=https://www.hundekari.in

# Optional remote drawer override — JSON array of drawer menu items the
# Android shell will render *instead of* its baked-in default menu. Each
# item: {id, titleMr, titleEn, path, requiresFarmerId?}. Leave unset to
# use the app's default drawer.
# WEB_MENU_ITEMS=[{"id":"schemes","titleMr":"सरकारी योजना","titleEn":"Govt schemes","path":"/schemes"}]
